NODE_ENV=development
PORT=3001
TRUST_PROXY=false
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://social_web:social_web@localhost:5432/social_web?schema=public
PRISMA_QUERY_LOG=false

REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=social-web-dev
BULLMQ_JOB_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY_MS=5000
BULLMQ_REMOVE_ON_COMPLETE=1000
BULLMQ_REMOVE_ON_FAIL=5000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=social-web-dev
CLOUDINARY_SECURE=true

JWT_ACCESS_TOKEN_SECRET=change-this-local-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=change-this-local-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

LOG_FORMAT=pretty
LOG_LEVEL=debug
