// =====================================================
// DATASOURCE & GENERATOR
// =====================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// ENUMS
// =====================================================

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum FeedReason {
  FOLLOWING // Post từ người đang follow
  FRIEND_ACTIVITY // Hoạt động của bạn bè
  TRENDING // Post hot trong cộng đồng
  RECOMMENDED // Gợi ý dựa trên thuật toán
  MENTIONED // Ai đó mention bạn
}

enum PostVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum NotificationType {
  FRIEND_REQUEST_RECEIVED
  FRIEND_REQUEST_ACCEPTED
  POST_REACTION
  POST_COMMENT
  COMMENT_REPLY
  COMMENT_REACTION
  MESSAGE_RECEIVED
  MENTIONED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  STICKER
  FILE
}

enum ConversationRole {
  MEMBER
  ADMIN
  MODERATOR
}

enum ReportType {
  POST
  COMMENT
  USER
}

enum ShareType {
  REPOST
  QUOTE
}

enum ReportStatus {
  PENDING
  REVIEWED
  REJECTED
}

enum StoryVisibility {
  PUBLIC
  FRIENDS
  CLOSE_FRIENDS
}

enum PostType {
  TEXT
  MEDIA
  SHARE
  SYSTEM
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum Permission {
  DELETE_POST
  REVIEW_REPORT
  BAN_USER
  FEATURE_POST
  MANAGE_STORIES
}

// =====================================================
// USER CORE
// =====================================================

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  username  String? @unique
  password  String
  fullName  String
  avatarUrl String?

  role UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  followerCount  Int     @default(0)
  followingCount Int     @default(0)
  isHighFollower Boolean @default(false)

  profile          UserProfile?
  posts            Post[]
  reactions        Reaction[]
  comments         Comment[]
  commentReactions CommentReaction[]

  sentFriendRequests     FriendRequest[] @relation("SentRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedRequests")

  friendshipsAsUser1 Friendship[] @relation("FriendshipUser1")
  friendshipsAsUser2 Friendship[] @relation("FriendshipUser2")

  feedItems            Feed[]
  notifications        Notification[] @relation("UserNotifications")
  actorInNotifications Notification[] @relation("ActorNotifications")

  blocksInitiated Block[] @relation("Blocker")
  blocksReceived  Block[] @relation("Blocked")

  conversationMembers ConversationMember[]
  messages            Message[]
  messageReads        MessageRead[]

  following Follow[] @relation("Following") // mình follow ai
  followers Follow[] @relation("Followers") // ai follow mình

  savedPosts SavedPost[]
  reports    Report[]
  stories    Story[]
  sessions   Session[]
  storyViews StoryView[]

  @@index([createdAt])
  @@index([isHighFollower])
  @@index([followerCount])
}

model RolePermission {
  role       UserRole
  permission Permission

  @@id([role, permission])
}

model ConversationPermission {
  conversationRole ConversationRole
  permission       Permission

  @@id([conversationRole, permission])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId, createdAt])
}

model SavedPost {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId, createdAt])
}

model Report {
  id              String       @id @default(uuid())
  reporterId      String
  targetUserId    String?
  targetPostId    String?
  targetCommentId String?
  type            ReportType
  reason          String?
  createdAt       DateTime     @default(now())
  status          ReportStatus @default(PENDING)
  reviewedAt      DateTime?

  reporter User @relation(fields: [reporterId], references: [id])

  @@index([targetUserId, type])
  @@index([targetPostId, type])
  @@index([targetCommentId, type])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  visibility StoryVisibility @default(FRIENDS)

  viewCount Int @default(0)

  deletedAt DateTime?

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  media StoryMedia[]
  views StoryView[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model StoryMedia {
  id      String    @id @default(uuid())
  storyId String
  url     String
  type    MediaType
  order   Int       @default(0)

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, order])
}

model StoryView {
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([userId])
  @@index([storyId, viewedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  createdAt DateTime @default(now())
  metadata  Json?

  @@index([entity, entityId])
}

model Session {
  id     String @id @default(uuid())
  userId String

  refreshTokenHash String @unique

  device    String?
  deviceId  String?
  ip        String? @db.Inet
  userAgent String?

  isRevoked    Boolean   @default(false)
  revokeReason String?
  revokedAt    DateTime?

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRevoked])
  @@index([expiresAt])
  @@index([isRevoked, expiresAt])
}

model RateLimit {
  identifier String // userId hoặc IP
  action     String // login, send_message, etc.

  count Int

  // window control
  window        Int // seconds
  lastRequestAt DateTime
  expiresAt     DateTime

  // optional abuse control
  blockedUntil DateTime?

  @@id([identifier, action])
  @@index([expiresAt])
}

// =====================================================
// USER PROFILE
// =====================================================

model UserProfile {
  userId String @id

  bio String?

  // location (normalized)
  locationName String?
  locationLat  Float?
  locationLng  Float?

  birthday DateTime?

  // privacy
  isBirthdayPublic   Boolean @default(false)
  isFriendListPublic Boolean @default(true)

  // social profile
  coverUrl           String?
  website            String?
  gender             String?
  relationshipStatus String?

  friendCount Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([friendCount])
  @@index([locationName])
  @@index([locationLat, locationLng])
}

// =====================================================
// BLOCK
// =====================================================

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

// =====================================================
// FRIEND SYSTEM
// =====================================================

model Friendship {
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  user1 User @relation("FriendshipUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("FriendshipUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@id([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([user1Id, createdAt])
  @@index([user2Id, createdAt])
  @@index([user1Id, user2Id])
}

model FriendRequest {
  id String @id @default(uuid()) // Thêm id riêng cho dễ quản lý

  requesterId String
  receiverId  String

  status FriendRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId]) // Ngăn A gửi B nhiều lần
  @@unique([receiverId, requesterId]) // ← QUAN TRỌNG: Ngăn B gửi A khi A đã gửi B
  @@index([receiverId, status])
  @@index([requesterId, status])
  @@index([createdAt])
}

// =====================================================
// POST
// =====================================================

model Post {
  id         String         @id @default(uuid())
  authorId   String
  content    String         @db.Text
  type       PostType       @default(TEXT)
  visibility PostVisibility @default(PUBLIC)

  originalPostId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  isHidden  Boolean @default(false)
  isFlagged Boolean @default(false)

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  originalPost Post?  @relation("PostShare", fields: [originalPostId], references: [id])
  sharedPosts  Post[] @relation("PostShare")

  media      Media[]
  stats      PostStats?
  reactions  Reaction[]
  comments   Comment[]
  feedItems  Feed[]
  savedPosts SavedPost[]

  @@index([authorId, createdAt])
  @@index([createdAt, id])
  @@index([visibility, createdAt])
  @@index([deletedAt])
  @@index([authorId, deletedAt, createdAt])
}

// =====================================================
// POST STATS
// =====================================================

model PostStats {
  postId String @id

  likeCount          Int @default(0)
  loveCount          Int @default(0)
  hahaCount          Int @default(0)
  wowCount           Int @default(0)
  sadCount           Int @default(0)
  angryCount         Int @default(0)
  commentCount       Int @default(0)
  shareCount         Int @default(0)
  totalReactionCount Int @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// =====================================================
// MEDIA
// =====================================================

model Media {
  id           String    @id @default(uuid())
  postId       String
  url          String
  thumbnailUrl String?
  mimeType     String?
  size         Int?
  type         MediaType
  width        Int?
  height       Int?
  duration     Int? // seconds, for video
  order        Int       @default(0) //order many image and video
  alt          String? //  accessibility

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, order])
}

// =====================================================
// REACTION (on Post)
// =====================================================

model Reaction {
  userId String
  postId String
  type   ReactionType

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, createdAt])
  @@index([userId])
  @@index([postId, type])
}

// =====================================================
// COMMENT (Nested)
// =====================================================

model Comment {
  id     String @id @default(uuid())
  userId String
  postId String

  parentId String?
  rootId   String
  path     String
  depth    Int

  content String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  isHidden  Boolean @default(false)
  isFlagged Boolean @default(false)

  score Float?

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  post                 Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent               Comment?             @relation("CommentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children             Comment[]            @relation("CommentTree")
  reactions            CommentReaction[]
  commentEditHistories CommentEditHistory[]
  commentStats         CommentStats[]

  @@index([userId])
  @@index([postId, createdAt])
  @@index([postId, depth, createdAt])
  @@index([parentId, createdAt])
  @@index([rootId])
  @@index([postId, score])
  @@index([rootId, createdAt])
}

model CommentEditHistory {
  id        String   @id @default(uuid())
  commentId String
  content   String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt])
}

model CommentStats {
  commentId String @id

  replyCount    Int @default(0)
  reactionCount Int @default(0)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

// =====================================================
// COMMENT REACTION
// =====================================================

model CommentReaction {
  userId    String
  commentId String
  type      ReactionType
  createdAt DateTime     @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId, type])
  @@index([commentId])
}

// =====================================================
// FEED
// =====================================================

model Feed {
  userId    String
  postId    String
  createdAt DateTime    @default(now())
  score     Float       @default(0)
  reason    FeedReason?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@index([userId, score])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, score, createdAt(sort: Desc)])
  @@index([userId, reason, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc), postId])
}

// =====================================================
// NOTIFICATION
// =====================================================

model Notification {
  id      String           @id @default(uuid())
  userId  String
  actorId String?
  type    NotificationType
  refId   String?
  message String?

  readAt DateTime?

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  aggregateKey String?
  count        Int     @default(1)

  user  User  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([userId, aggregateKey])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, aggregateKey])
  @@index([actorId])
  @@index([type, createdAt])
}

// =====================================================
// CHAT SYSTEM
// =====================================================

model Conversation {
  id        String  @id @default(uuid())
  name      String?
  avatarUrl String?
  isGroup   Boolean @default(false)

  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([lastMessageAt(sort: Desc)])
}

model ConversationMember {
  conversationId String
  userId         String
  role           ConversationRole @default(MEMBER)

  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)

  content   String
  mediaUrl  String?
  deletedAt DateTime?

  createdAt DateTime @default(now())

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reads        MessageRead[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// =====================================================
// MESSAGE READ RECEIPTS
// Tracks per-user read status (scales to group chat)
// =====================================================

model MessageRead {
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId])
}
