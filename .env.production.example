# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql://user:password@host/database?channel_binding=require&sslmode=require

# =============================================================================
# REDIS & QUEUE
# =============================================================================

REDIS_PASSWORD=change-this-redis-password

BULLMQ_PREFIX=social-web-prod
BULLMQ_JOB_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY_MS=5000
BULLMQ_REMOVE_ON_COMPLETE=1000
BULLMQ_REMOVE_ON_FAIL=5000

# =============================================================================
# APPLICATION
# =============================================================================

WEB_PORT=3000

CORS_ORIGIN=https://your-domain.example
WEB_APP_URL=https://your-domain.example

API_URL=http://api:3001
API_PUBLIC_URL=https://api.your-domain.example

TRUST_PROXY=false

# =============================================================================
# AUTHENTICATION
# =============================================================================

JWT_ACCESS_TOKEN_SECRET=change-this-access-secret
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_TOKEN_SECRET=change-this-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# GOOGLE OAUTH
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.your-domain.example/auth/google/callback

OAUTH_STATE_SECRET=change-this-oauth-state-secret

# =============================================================================
# CLOUDINARY
# =============================================================================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CLOUDINARY_UPLOAD_FOLDER=social-web-prod
CLOUDINARY_SECURE=true

# =============================================================================
# LOGGING
# =============================================================================

LOG_FORMAT=json
LOG_LEVEL=info
PRISMA_QUERY_LOG=false